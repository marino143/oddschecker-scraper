# Port the API runs on
PORT=4000

# Your frontend URL for CORS
FRONTEND_URL=https://oddschecker2.netlify.app

# ZenRows API key
# Get from: https://app.zenrows.com/playground (top right corner "Copy API key")
ZENROWS_API_KEY=

# ZenRows Scraping Browser WebSocket URL
# Get from: https://app.zenrows.com/playground -> Scraping Browser
# Format: wss://browser.zenrows.com?apikey=YOUR_KEY&proxy_region=eu
ZENROWS_BROWSER_WSS=

# How often to scrape (milliseconds) — default 60s
SCRAPE_INTERVAL_MS=60000
